# Ansible Vault template generated by infra.satellite_configuration.filetree_create
#
# Before import:
#   1. Replace every "{{ satellite_configuration_vault_placeholder }}" value below.
#   2. Merge secrets into the matching CaC fragments under {{ output_path }}/ (see keys below).
#   3. Optional: ansible-vault encrypt {{ output_path }}/vault_template.yaml
#   4. Load with: ansible-playbook ... -e@my_vars/satellite.yaml -e@{{ output_path }}/vault_template.yaml
#
# Installation medium paths use "{{ satellite_configuration_installation_medium_path_placeholder }}" in
# satellite_installation_mediums.d/ — replace with the target Satellite FQDN before import.
---
vault_template_instructions:
  ldap: >-
    Set account_password on each matching entry in satellite_auth_sources_ldap.d/satellite_auth_sources_ldap.yaml
    (or populate filetree_create_auth_sources_ldap_account_passwords when re-exporting).
  users: >-
    Set user_password on each Internal-auth user in satellite_users.d/satellite_users.yaml, or define
    satellite_users_default_password for bootstrap only.
  settings: >-
    Replace redacted "*****" values in satellite_settings.d/satellite_settings.yaml for each name listed
    under satellite_settings_secrets.
  installation_mediums: >-
    Replace {{ satellite_configuration_installation_medium_path_placeholder }} in path fields with the target
    Satellite FQDN (or full URL host) before import.

satellite_auth_sources_ldap_secrets:
{% for __ldap_name in satellite_configuration_vault_template_ldap_sources | default([]) | unique | sort %}
  - name: {{ __ldap_name }}
    account_password: "{{ satellite_configuration_vault_placeholder }}"
{% else %}
  []
{% endfor %}

satellite_users_secrets:
{% for __user_login in satellite_configuration_vault_template_internal_users | default([]) | unique | sort %}
  - name: {{ __user_login }}
    user_password: "{{ satellite_configuration_vault_placeholder }}"
{% else %}
  []
{% endfor %}

satellite_users_default_password: "{{ satellite_configuration_vault_placeholder }}"

satellite_settings_secrets:
{% for __setting_name in satellite_configuration_vault_template_encrypted_settings | default([]) | unique | sort %}
  - name: {{ __setting_name }}
    value: "{{ satellite_configuration_vault_placeholder }}"
{% else %}
  []
{% endfor %}
