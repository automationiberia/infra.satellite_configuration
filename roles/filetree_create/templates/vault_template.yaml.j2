# Ansible Vault template generated by infra.satellite_configuration.filetree_create
#
# Usage:
#   1. Replace every placeholder value below with real secrets.
#   2. Optional: ansible-vault encrypt vault_template.yaml
#   3. Import: ansible-playbook ... -e@my_vars/satellite.yaml -e@{{ output_path }}/vault_template.yaml
#
# CaC fragments under {{ output_path }}/ reference these variables directly; no manual merge into .d/ files is required.
---
vault_satellite_auth_sources_ldap_account_passwords:
{% if satellite_configuration_vault_template_ldap_sources | default([]) | length > 0 %}
{% for __ldap_name in satellite_configuration_vault_template_ldap_sources | default([]) | unique | sort %}
  {{ __ldap_name | to_json }}: {{ satellite_configuration_vault_placeholder }}
{% endfor %}
{% else %}
  {}
{% endif %}

vault_satellite_users_passwords:
{% if satellite_configuration_vault_template_internal_users | default([]) | length > 0 %}
{% for __user_login in satellite_configuration_vault_template_internal_users | default([]) | unique | sort %}
  {{ __user_login | to_json }}: {{ satellite_configuration_vault_placeholder }}
{% endfor %}
{% else %}
  {}
{% endif %}

vault_satellite_users_default_password: {{ satellite_configuration_vault_placeholder }}

vault_satellite_settings:
{% if satellite_configuration_vault_template_encrypted_settings | default([]) | length > 0 %}
{% for __setting_name in satellite_configuration_vault_template_encrypted_settings | default([]) | unique | sort %}
  {{ __setting_name | to_json }}: {{ satellite_configuration_vault_placeholder }}
{% endfor %}
{% else %}
  {}
{% endif %}

vault_satellite_settings_host_specific:
{% for __host_setting_name in satellite_settings_host_specific_names %}
  {{ __host_setting_name | to_json }}: {{ satellite_configuration_vault_placeholder }}
{% endfor %}

{% if satellite_configuration_vault_template_installation_mediums_fqdn | default(false) %}
vault_satellite_installation_mediums_target_fqdn: {{ satellite_configuration_vault_placeholder }}
{% endif %}
