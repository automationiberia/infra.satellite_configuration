# Ansible Vault template generated by infra.satellite_configuration.filetree_create
#
# Fill every placeholder below before import. Optional: ansible-vault encrypt this file.
# Import: ansible-playbook ... -e@my_vars/satellite.yaml -e@{{ output_path }}/vault_template.yaml
#
# CaC fragments under {{ output_path }}/ reference these variables directly.
{% from 'vault_entity_parameters.j2' import render_vault_entity_parameters_section %}
---
# REQUIRED — LDAP bind passwords (one entry per exported auth source name)
vault_satellite_auth_sources_ldap_account_passwords:
{% if satellite_configuration_vault_template_ldap_sources | default([]) | length > 0 %}
{%   for __ldap_name in satellite_configuration_vault_template_ldap_sources | default([]) | unique | sort %}
  {{ __ldap_name | to_json }}: {{ satellite_configuration_vault_placeholder }}  # password
{%   endfor %}
{% else %}
  {}
{% endif %}

# REQUIRED — Internal-auth Satellite user passwords (login -> password)
vault_satellite_users_passwords:
{% if satellite_configuration_vault_template_internal_users | default([]) | length > 0 %}
{%   for __user_login in satellite_configuration_vault_template_internal_users | default([]) | unique | sort %}
  {{ __user_login | to_json }}: {{ satellite_configuration_vault_placeholder }}  # password
{%   endfor %}
{% else %}
  {}
{% endif %}

# REQUIRED when exported users omit user_password — fallback for new Internal users
vault_satellite_users_default_password: {{ satellite_configuration_vault_placeholder }}  # password

# Encrypted Foreman settings — replace placeholders; empty string is valid where noted in Satellite UI
vault_satellite_settings:
{% if satellite_configuration_vault_template_encrypted_settings | default([]) | length > 0 %}
{%   for __setting_name in satellite_configuration_vault_template_encrypted_settings | default([]) | unique | sort %}
  {{ __setting_name | to_json }}: {{ satellite_configuration_vault_placeholder }}
{%   endfor %}
{% else %}
  {}
{% endif %}

# REQUIRED — unique per target Satellite instance (UUIDs and target URLs)
vault_satellite_settings_host_specific:
{% for __host_setting_name in satellite_settings_host_specific_names %}
  {{ __host_setting_name | to_json }}: {{ satellite_configuration_vault_placeholder }}
{% endfor %}

{{ render_vault_entity_parameters_section(
  'vault_satellite_hostgroup_parameters',
  satellite_configuration_vault_template_hostgroup_parameters,
  'REQUIRED — hidden host group parameters (masked in the Satellite API as *****)',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_operatingsystem_parameters',
  satellite_configuration_vault_template_operatingsystem_parameters,
  'REQUIRED — hidden operating system parameters',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_domain_parameters',
  satellite_configuration_vault_template_domain_parameters,
  'REQUIRED — hidden domain parameters',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_subnet_parameters',
  satellite_configuration_vault_template_subnet_parameters,
  'REQUIRED — hidden subnet parameters',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_organization_parameters',
  satellite_configuration_vault_template_organization_parameters,
  'REQUIRED — hidden organization parameters',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_location_parameters',
  satellite_configuration_vault_template_location_parameters,
  'REQUIRED — hidden location parameters',
  satellite_configuration_vault_placeholder
) }}
{{ render_vault_entity_parameters_section(
  'vault_satellite_job_template_inputs',
  satellite_configuration_vault_template_job_template_inputs,
  'REQUIRED — hidden job template input defaults (masked in the Satellite API as *****)',
  satellite_configuration_vault_placeholder
) }}

{% if satellite_configuration_vault_template_installation_mediums_fqdn | default(false) %}
# REQUIRED for cross-host import — target Satellite FQDN used in installation medium paths
vault_satellite_installation_mediums_target_fqdn: {{ satellite_configuration_vault_placeholder }}  # hostname/FQDN
{% endif %}
